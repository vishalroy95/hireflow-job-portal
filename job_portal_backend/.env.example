# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/job_portal

# MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/job_portal

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production_make_it_strong_and_unique
JWT_EXPIRE=7d

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# CORS Configuration
# Comma-separated list for production/staging. Local development ports are allowed automatically.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
FRONTEND_URL=http://localhost:5173
CANDIDATE_FRONTEND_URL=http://localhost:5173
RECRUITER_FRONTEND_URL=http://localhost:5173

# AWS example without Docker, if frontend/admin/backend share one domain through Nginx:
# CORS_ORIGIN=https://yourdomain.com
# FRONTEND_URL=https://yourdomain.com
# CANDIDATE_FRONTEND_URL=https://yourdomain.com
# RECRUITER_FRONTEND_URL=https://yourdomain.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Email / Gmail SMTP
# For Gmail, enable 2-Step Verification in your Google Account, then create an App Password.
EMAIL_PROVIDER=smtp
EMAIL_FROM_NAME=HireFlow
EMAIL_FROM=your-gmail-address@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASSWORD=your-16-character-gmail-app-password

# AI Resume Analyzer
# Enable/disable and model are controlled from Admin Settings > AI Resume Analyzer.
# Keep only the secret API key in .env.
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key

# Razorpay Payments
RAZORPAY_KEY_ID=your-razorpay-test-or-live-key-id
RAZORPAY_KEY_SECRET=your-razorpay-test-or-live-key-secret
